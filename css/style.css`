/*
  DESIGN SYSTEM: Cinematic Editorial
  Project: JT Areias
  Palette:
  - Primary Background: #181818 (Matte Black)
  - Primary Text: #EBDCC4 (Warm Beige)
  - Secondary Text: #B6A596 (Muted Sage)
  - Accent: #DC9F85 (Coral Rust)
  - Borders: #66473B (Deep Earth)
  - Dividers: #35211A (Burnt Umber)
*/

:root {
    --bg-color: #181818;
    --text-primary: #EBDCC4;
    --text-secondary: #B6A596;
    --accent-color: #DC9F85;
    --border-color: #66473B;
    --divider-color: #35211A;
    --font-display: 'Space Grotesk', sans-serif;
    --font-body: 'Inter', sans-serif;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-weight: 300;
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
}

/* Fractal Noise Overlay */
.noise-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65536' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
}

/* Navigation */
.nav-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 3rem;
    z-index: 100;
}

.nav-left {
    font-family: var(--font-display);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.75rem;
    font-weight: 500;
}

.nav-center {
    flex-grow: 1;
    max-width: 200px;
    height: 1px;
    background-color: var(--divider-color);
    margin: 0 2rem;
}

.nav-right {
    font-family: var(--font-display);
    color: var(--divider-color);
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.1em;
}

/* Hero Section */
.hero {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 3rem;
}

.pre-title {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
}

.pre-title .line {
    width: 24px;
    height: 1px;
    background-color: var(--accent-color);
}

.pre-title .text {
    color: var(--text-secondary);
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    font-family: var(--font-display);
}

.main-title {
    position: relative;
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 11.5vw;
    line-height: 0.85;
    letter-spacing: -0.04em;
    margin-bottom: 3rem;
}

.title-back {
    position: absolute;
    top: 4px;
    left: 4px;
    -webkit-text-stroke: 1px var(--border-color);
    color: transparent;
    z-index: -1;
}

.title-front {
    color: var(--text-primary);
}

.hero-subtitle {
    font-size: 1.2rem;
    max-width: 600px;
    color: var(--text-secondary);
    font-weight: 300;
    margin-bottom: 2rem;
}

.cta-button {
    display: inline-block;
    background-color: var(--accent-color);
    color: var(--bg-color);
    text-decoration: none;
    padding: 1rem 2.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    border-radius: 0 4px 0 4px; /* Custom rounding */
    transition: opacity 0.3s ease;
}

.cta-button:hover {
    opacity: 0.9;
}

/* Bottom Grid */
.bottom-divider {
    width: 100%;
    height: 1px;
    background-color: var(--divider-color);
}

.bottom-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    padding: 4rem 3rem;
    gap: 2rem;
}

.exclusivity-statement {
    grid-column: span 5;
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--text-primary);
}

.status-indicator {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    font-family: var(--font-display);
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--text-secondary);
}

.status-dot {
    width: 8px;
    height: 8px;
    background-color: var(--accent-color);
    border-radius: 50%;
}

.email-capture {
    grid-column: 7 / span 6;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.form-group {
    display: flex;
    position: relative;
}

.form-input {
    width: 100%;
    background: transparent;
    border: 1px solid var(--border-color);
    padding: 1rem;
    color: var(--text-primary);
    font-family: var(--font-body);
    border-radius: 4px 0 4px 0;
    outline: none;
}

.form-input::placeholder {
    color: var(--border-color);
}

.form-submit {
    background-color: var(--accent-color);
    color: var(--bg-color);
    border: none;
    padding: 0 2rem;
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 0 4px 0 4px;
    transition: opacity 0.3s ease;
}

.form-caption {
    font-size: 0.6rem;
    color: var(--divider-color);
    text-transform: uppercase;
    margin-top: 0.5rem;
}

/* Rotating Badge */
.rotating-badge {
    position: fixed;
    bottom: 3rem;
    right: 3rem;
    width: 64px;
    height: 64px;
    z-index: 1000;
}

.rotating-badge svg {
    width: 100%;
    height: 100%;
}

.rotating-badge circle {
    stroke: var(--divider-color);
}

.rotating-badge text {
    fill: var(--divider-color);
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    animation: rotateText 12s linear infinite;
}

@keyframes rotateText {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* Responsive */
@media (max-width: 768px) {
    .nav-bar {
        padding: 1.5rem;
    }
    .main-title {
        font-size: 16vw;
    }
    .bottom-grid {
        display: flex;
        flex-direction: column;
        padding: 2rem 1.5rem;
    }
    .exclusivity-statement, .email-capture {
        grid-column: auto;
        width: 100%;
    }
    .rotating-badge {
        bottom: 1.5rem;
        right: 1.5rem;
    }
}
